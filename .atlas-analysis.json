  "keyFeatures": [
    "Multi-tenant company management with full data isolation",
    "JWT stateless authentication with access and refresh tokens",
    "Role-based access control (PLATFORM_ADMIN, COMPANY_ADMIN, AGENT, USER)",
    "Comprehensive ticket lifecycle management with responses and attachments",
    "Announcements system (alerts, news, incidents, maintenance) with scheduling",
    "Help center with categorized articles and publish/draft workflow",
    "PostgreSQL multi-schema design (auth, business, ticketing, audit)",
    "Docker-based production-ready infrastructure with Redis caching",
    "174+ automated tests with PHPUnit",
    "OpenAPI/Swagger documentation"
  ],
